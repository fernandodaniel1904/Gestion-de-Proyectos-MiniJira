@model Gestion_de_Proyectos_MiniJira.Models.Proyecto

@{
    ViewData["Title"] = "Detalles del Proyecto";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.Nombre</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Información del Proyecto</h5>
                <p><strong>Descripción:</strong> @Model.Descripcion</p>
                <p><strong>Estado:</strong> 
                    @if (Model.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoProyecto.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else if (Model.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoProyecto.Pausado)
                    {
                        <span class="badge bg-warning">Pausado</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Finalizado</span>
                    }
                </p>
                <p><strong>Fecha de Creación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy")</p>
                @if (Model.FechaVencimiento.HasValue)
                {
                    <p><strong>Fecha de Vencimiento:</strong> @Model.FechaVencimiento?.ToString("dd/MM/yyyy")</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Tareas (@Model.Tareas.Count)</h3>
    <a asp-controller="Tareas" asp-action="Create" asp-route-proyectoId="@Model.Id" class="btn btn-success">+ Nueva Tarea</a>
</div>

@if (Model.Tareas.Any())
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Título</th>
                <th>Estado</th>
                <th>Prioridad</th>
                <th>Vencimiento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tarea in Model.Tareas)
            {
                <tr>
                    <td>@tarea.Titulo</td>
                    <td>
                        @if (tarea.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoTarea.PorHacer)
                        {
                            <span class="badge bg-secondary">Por Hacer</span>
                        }
                        else if (tarea.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoTarea.EnProgreso)
                        {
                            <span class="badge bg-info">En Progreso</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Completada</span>
                        }
                    </td>
                    <td>
                        @if (tarea.Prioridad == Gestion_de_Proyectos_MiniJira.Models.Prioridad.Baja)
                        {
                            <span class="badge bg-success">Baja</span>
                        }
                        else if (tarea.Prioridad == Gestion_de_Proyectos_MiniJira.Models.Prioridad.Media)
                        {
                            <span class="badge bg-warning">Media</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Alta</span>
                        }
                    </td>
                    <td>@tarea.FechaVencimiento?.ToString("dd/MM/yyyy")</td>
                    <td>
                        <a asp-controller="Tareas" asp-action="Edit" asp-route-id="@tarea.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-controller="Tareas" asp-action="Delete" asp-route-id="@tarea.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info" role="alert">
        <p>Este proyecto no tiene tareas. <a asp-controller="Tareas" asp-action="Create" asp-route-proyectoId="@Model.Id">Crea una aquí</a></p>
    </div>
}
