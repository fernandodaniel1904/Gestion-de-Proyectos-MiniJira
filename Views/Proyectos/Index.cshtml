@model IEnumerable<Gestion_de_Proyectos_MiniJira.Models.Proyecto>

@{
    ViewData["Title"] = "Proyectos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📊 Mis Proyectos</h1>
    <a asp-action="Create" class="btn btn-success">+ Nuevo Proyecto</a>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="card-text">@item.Descripcion</p>
                        <div class="mb-3">
                            <span class="badge bg-info">@item.Tareas.Count tareas</span>
                            @if (item.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoProyecto.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else if (item.Estado == Gestion_de_Proyectos_MiniJira.Models.EstadoProyecto.Pausado)
                            {
                                <span class="badge bg-warning">Pausado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Finalizado</span>
                            }
                        </div>
                        @if (item.FechaVencimiento.HasValue)
                        {
                            <small class="text-muted">📅 @item.FechaVencimiento?.ToString("dd/MM/yyyy")</small>
                        }
                    </div>
                    <div class="card-footer bg-white">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver Detalles</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        <h4 class="alert-heading">No hay proyectos</h4>
        <p>No tienes ningún proyecto creado. <a asp-action="Create">Crea uno aquí</a></p>
    </div>
}
