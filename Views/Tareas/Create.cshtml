@model Gestion_de_Proyectos_MiniJira.Models.Tarea

@{
    ViewData["Title"] = "Crear Tarea";
}

<h1>Crear Nueva Tarea</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Titulo" class="form-label"></label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="FechaVencimiento" class="form-label"></label>
                <input asp-for="FechaVencimiento" type="date" class="form-control" />
                <span asp-validation-for="FechaVencimiento" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Estado" class="form-label"></label>
                <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<Gestion_de_Proyectos_MiniJira.Models.EstadoTarea>()"></select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Prioridad" class="form-label"></label>
                <select asp-for="Prioridad" class="form-select" asp-items="Html.GetEnumSelectList<Gestion_de_Proyectos_MiniJira.Models.Prioridad>()"></select>
                <span asp-validation-for="Prioridad" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="ProyectoId" class="form-label">Proyecto</label>
                <input type="hidden" asp-for="ProyectoId" value="@ViewBag.ProyectoId" />
                @if (ViewBag.Proyecto != null)
                {
                    <input type="text" class="form-control" value="@ViewBag.Proyecto.Nombre" disabled />
                }
                else
                {
                    <input asp-for="ProyectoId" class="form-control" type="number" />
                }
                <span asp-validation-for="ProyectoId" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary">Crear</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
