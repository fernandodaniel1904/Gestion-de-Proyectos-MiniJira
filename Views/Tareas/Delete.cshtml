@model Gestion_de_Proyectos_MiniJira.Models.Tarea

@{
    ViewData["Title"] = "Eliminar Tarea";
}

<h1>Eliminar Tarea</h1>

<div class="alert alert-danger" role="alert">
    <h4 class="alert-heading">¿Estás seguro?</h4>
    <p>Esta acción eliminará la tarea <strong>@Model.Titulo</strong>.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@Model.Titulo</h5>
                <p>@Model.Descripcion</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
