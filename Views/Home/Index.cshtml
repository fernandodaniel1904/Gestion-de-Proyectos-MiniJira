@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center">
    <h1 class="display-4">Bienvenido a MiniJira</h1>
    <p class="lead">Sistema de Gestión de Proyectos y Tareas</p>
</div>

<div class="row mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">📊 Proyectos</h5>
                <p class="card-text">Gestiona tus proyectos y organiza tu trabajo.</p>
                <a href="/Proyectos" class="btn btn-primary">Ir a Proyectos</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">✅ Tareas</h5>
                <p class="card-text">Crea y sigue el progreso de tus tareas.</p>
                <a href="/Tareas" class="btn btn-primary">Ir a Tareas</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-12">
        <h3>Características</h3>
        <ul>
            <li>✅ CRUD completo de Proyectos y Tareas</li>
            <li>✅ Patrón Repository Pattern</li>
            <li>✅ Entity Framework Core (Code-First)</li>
            <li>✅ API REST (JSON)</li>
            <li>✅ Inyección de Dependencias</li>
            <li>✅ Base de datos SQL Server</li>
        </ul>
    </div>
</div>
